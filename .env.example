# ══════════════════════════════════════════════════
# 飞书推送配置
# ══════════════════════════════════════════════════

# 推送模式: "webhook" (群机器人) 或 "api" (个人推送)
FEISHU_MODE=api

# ── 模式 A: 群机器人 Webhook（FEISHU_MODE=webhook 时填写）──
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxx
# FEISHU_WEBHOOK_SECRET=your_secret_here

# ── 模式 B: 个人推送 API（FEISHU_MODE=api 时填写）──
# 从飞书开发者后台 -> 应用设置页 获取
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=your_app_secret_here

# 你的飞书用户 Open ID（从飞书开发者后台 -> 用户管理 获取，格式：ou_xxxxxx）
FEISHU_USER_OPEN_ID=ou_xxxxxxxxxxxx

# ══════════════════════════════════════════════════
# LinkedIn 账号（可选，不填则跳过 LinkedIn 采集）
# ══════════════════════════════════════════════════
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# ══════════════════════════════════════════════════
# 数据库路径（默认使用项目目录下的 data/food_news.db）
# ══════════════════════════════════════════════════
DATABASE_PATH=data/food_news.db

# ══════════════════════════════════════════════════
# 日志级别 (DEBUG, INFO, WARNING, ERROR)
# ══════════════════════════════════════════════════
LOG_LEVEL=INFO
